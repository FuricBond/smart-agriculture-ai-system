# Python Runtime
__pycache__/
*.py[cod]
*$py.class

# Jupyter Notebooks
.ipynb_checkpoints/

# Virtual Environments
venv/
env/
.env

# Node.js
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# VS Code / IDEs
.vscode/
.idea/
*.swp
*.swo

# Temporary & Log Files
*.tmp
*.temp
*.bak
*.log
logs/
reports/

# Data & Datasets
# Exclude raw and processed data (too large for GitHub)
data/
datasets/
disease_model/data/
crop_model/data/
yield_model/data/
*.csv
*.xlsx

# Machine Learning Models
# Exclude the large crop model and globally ignore general extensions
*.h5
*.onnx

# Explicitly ignore the large crop recommendation model
crop_model/models/improved_crop_model.pkl

# Allow tracking of specific small models
!disease_model/models/disease_model.pth
!yield_model/models/yield_model.pkl
!yield_model/models/area_encoder.pkl
!yield_model/models/crop_encoder.pkl
!crop_model/models/label_encoder.pkl

# Specific Debug / Old / Test files
debug_*.py
test_*.py
old_*.py
